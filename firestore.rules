rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isPrimaryAdmin() {
      return signedIn() && request.auth.token.email == 'manavsinghal@gmail.com';
    }

    function isApproved() {
      return isPrimaryAdmin() || (
        signedIn() &&
        exists(/databases/$(database)/documents/authorizedUsers/$(request.auth.token.email))
      );
    }

    match /authorizedUsers/{email} {
      allow get: if isPrimaryAdmin() || (
        signedIn() && request.auth.token.email == email
      );
      allow list, create, update, delete: if isPrimaryAdmin();
    }

    match /{document=**} {
      allow read, write: if isApproved();
    }
  }
}
